# Main Shopify app – copy to .env and fill in values.
# Current Supabase project: ztjxsssrbmftxshidcfq
# Dashboard: https://supabase.com/dashboard/project/ztjxsssrbmftxshidcfq

# Shopify (from Partners or: shopify app env show)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_inventory,read_locations,write_inventory,write_products
SHOPIFY_APP_URL=https://speedy-motor-vin-cloud.vercel.app

# Database – same Supabase project (Settings → Database → Connection string)
# Use pooler (port 6543) for runtime; direct (port 5432) for migrations.
DATABASE_URL=postgresql://postgres.ztjxsssrbmftxshidcfq:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.ztjxsssrbmftxshidcfq.supabase.co:5432/postgres?sslmode=require

# Reels API (optional)
REELS_API_URL=https://your-reels-api.vercel.app
REELS_ADMIN_SECRET=

# Optional
# SHOP_CUSTOM_DOMAIN=
