{% comment %}
  Section: Vehicle specs from VIN Decoder metafields.
  Copy to theme: sections/vehicle-specs-vin.liquid
  Add via: Customize → Product page → Add section → "Vehicle specs (VIN)"
  Layout: Vehicle details + VIN, then two-column grid with icon + value (like dealer listings).
{% endcomment %}
{% assign vin = product.metafields.vin_decoder.vin %}
{% assign decoded = product.metafields.vin_decoder.decoded.value %}
{% assign icon_color = section.settings.icon_color | default: '#b22222' %}

{% if vin != blank or decoded != nil %}
  <div class="vehicle-specs-vin section-{{ section.id }}-padding" {{ block.shopify_attributes }}>
    <div class="vehicle-specs-vin__inner">
      {% if section.settings.heading != blank %}
        <h2 class="vehicle-specs-vin__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if vin != blank %}
        <p class="vehicle-specs-vin__vin">
          <span class="vehicle-specs-vin__icon" style="color: {{ icon_color }}"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M4 6h16M4 10h16M4 14h16M4 18h12"/><rect x="2" y="4" width="20" height="16" rx="1" fill="none" stroke="currentColor" stroke-width="2"/></svg></span>
          <strong>VIN:</strong> {{ vin }}
        </p>
      {% endif %}
      {% if decoded != nil %}
        <div class="vehicle-specs-vin__two-col">
          <div class="vehicle-specs-vin__col">
            {% if decoded.year != blank %}
              <div class="vehicle-specs-vin__row"><span class="vehicle-specs-vin__icon" style="color: {{ icon_color }}"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span><span class="vehicle-specs-vin__value">{{ decoded.year }}</span></div>
            {% endif %}
            {% if decoded.make != blank %}
              <div class="vehicle-specs-vin__row"><span class="vehicle-specs-vin__icon" style="color: {{ icon_color }}"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/></svg></span><span class="vehicle-specs-vin__value">{{ decoded.make }}</span></div>
            {% endif %}
            {% if decoded.model != blank %}
              <div class="vehicle-specs-vin__row"><span class="vehicle-specs-vin__icon" style="color: {{ icon_color }}"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M5 17h14v-5H5v5z"/><path d="M5 12L3 8h18l-2 4"/><circle cx="7.5" cy="17" r="1.5"/><circle cx="16.5" cy="17" r="1.5"/></svg></span><span class="vehicle-specs-vin__value">{{ decoded.model }}</span></div>
            {% endif %}
            {% if decoded.trim != blank %}
              <div class="vehicle-specs-vin__row"><span class="vehicle-specs-vin__icon" style="color: {{ icon_color }}"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg></span><span class="vehicle-specs-vin__value">{{ decoded.trim }}</span></div>
            {% endif %}
            {% comment %} Show one vehicle type only; normalize to standard labels: SUV, SEDAN, COUPE, Pickup, etc. {% endcomment %}
            {% assign vehicle_type_raw = decoded.bodyClass | default: decoded.vehicleType %}
            {% if vehicle_type_raw != blank %}
              {% assign bt = vehicle_type_raw | upcase %}
              {% assign body_normalized = vehicle_type_raw %}
              {% if bt contains 'PICKUP' or bt contains 'TRUCK' %}{% assign body_normalized = 'Pickup' %}
              {% elsif bt contains 'SUV' or bt contains 'SPORT UTILITY' or bt contains 'MULTI-PURPOSE' or bt contains 'MPV' %}{% assign body_normalized = 'SUV' %}
              {% elsif bt contains 'SEDAN' or bt contains 'PASSENGER CAR' %}{% assign body_normalized = 'SEDAN' %}
              {% elsif bt contains 'COUPE' %}{% assign body_normalized = 'COUPE' %}
              {% elsif bt contains 'HATCHBACK' %}{% assign body_normalized = 'HATCHBACK' %}
              {% elsif bt contains 'CONVERTIBLE' %}{% assign body_normalized = 'CONVERTIBLE' %}
              {% elsif bt contains 'WAGON' %}{% assign body_normalized = 'WAGON' %}
              {% elsif bt contains 'VAN' or bt contains 'MINIVAN' %}{% assign body_normalized = 'VAN' %}
              {% endif %}
              <div class="vehicle-specs-vin__row"><span class="vehicle-specs-vin__icon" style="color: {{ icon_color }}"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M19 17h2a1 1 0 001-1v-4a1 1 0 00-1-1H3a1 1 0 00-1 1v4a1 1 0 001 1h2"/><path d="M5 13h14V8H5z"/><circle cx="7.5" cy="18" r="1.5"/><circle cx="16.5" cy="18" r="1.5"/></svg></span><span class="vehicle-specs-vin__value">{{ body_normalized }}</span></div>
            {% endif %}
          </div>
          <div class="vehicle-specs-vin__col">
            {% if decoded.engineCylinders != blank or decoded.displacementL != blank %}
              <div class="vehicle-specs-vin__row"><span class="vehicle-specs-vin__icon" style="color: {{ icon_color }}"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg></span><span class="vehicle-specs-vin__value">{{ decoded.engineCylinders }} cylinder{% if decoded.displacementL != blank %} {{ decoded.displacementL }}L{% endif %}</span></div>
            {% endif %}
            {% if decoded.fuelTypePrimary != blank %}
              <div class="vehicle-specs-vin__row"><span class="vehicle-specs-vin__icon" style="color: {{ icon_color }}"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M3 21v-6h4l2-6h4l2 6h4v6"/><path d="M3 15h18"/><path d="M8 9l2-6 2 6"/></svg></span><span class="vehicle-specs-vin__value">{{ decoded.fuelTypePrimary }}</span></div>
            {% endif %}
            {% if decoded.driveType != blank %}
              <div class="vehicle-specs-vin__row"><span class="vehicle-specs-vin__icon" style="color: {{ icon_color }}"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg></span><span class="vehicle-specs-vin__value">{{ decoded.driveType }}</span></div>
            {% endif %}
            {% if decoded.transmissionStyle != blank %}
              <div class="vehicle-specs-vin__row"><span class="vehicle-specs-vin__icon" style="color: {{ icon_color }}"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><circle cx="12" cy="12" r="3"/><path d="M12 1v3M12 20v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M1 12h3M20 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg></span><span class="vehicle-specs-vin__value">{{ decoded.transmissionStyle }}</span></div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
  <style>
    .vehicle-specs-vin__inner { margin: 1.5em 0; padding: 1.25em; border: 1px solid rgba(var(--color-foreground), 0.12); border-radius: 8px; background: rgba(var(--color-foreground), 0.03); }
    .vehicle-specs-vin__heading { margin: 0 0 0.75em; font-size: 1.25em; font-weight: 700; }
    .vehicle-specs-vin__vin { margin-bottom: 1em; font-size: 0.95em; display: flex; align-items: center; gap: 0.5em; }
    .vehicle-specs-vin__two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5em 2em; }
    @media (max-width: 600px) { .vehicle-specs-vin__two-col { grid-template-columns: 1fr; } }
    .vehicle-specs-vin__col { display: flex; flex-direction: column; gap: 0.6em; }
    .vehicle-specs-vin__row { display: flex; align-items: center; gap: 0.6em; }
    .vehicle-specs-vin__icon { flex-shrink: 0; width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; }
    .vehicle-specs-vin__icon svg { flex-shrink: 0; }
    .vehicle-specs-vin__value { font-weight: 500; }
  </style>
{% endif %}

{% schema %}
{
  "name": "Vehicle specs (VIN)",
  "tag": "section",
  "class": "section-vehicle-specs-vin",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Vehicle details"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#b22222"
    }
  ],
  "presets": [
    {
      "name": "Vehicle specs (VIN)"
    }
  ]
}
{% endschema %}
