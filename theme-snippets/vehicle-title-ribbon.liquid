{% comment %}
  VIN Decoder app – vehicle title type badge for product cards.
  Copy to theme: snippets/vehicle-title-ribbon.liquid
  Use inside your product card's image wrapper (position: relative), e.g.:
    {% render 'vehicle-title-ribbon', product: product %}
  Shows a "Clean" badge in the top-right only when product.metafields.vin_decoder.title_status is "Clean".
  Rectangle style (no rotation) so it isn't clipped by the card's overflow: hidden.
{% endcomment %}
{% assign title_type = product.metafields.vin_decoder.title_status | strip %}
{% if title_type == 'Clean' %}
  <span class="vehicle-title-ribbon vehicle-title-ribbon--clean" aria-label="Title: Clean">Clean</span>
  <style>
    .vehicle-title-ribbon {
      position: absolute;
      top: 10px;
      right: 10px;
      padding: 0.5em 1em;
      font-size: 0.9rem;
      font-weight: 700;
      line-height: 1.2;
      color: #fff;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      border-radius: 4px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.25);
      z-index: 2;
    }
    .vehicle-title-ribbon--clean {
      background: #2563eb;
    }
  </style>
{% endif %}
