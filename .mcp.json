{
  "mcpServers": {
    "shopify-dev-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@shopify/dev-mcp@latest"]
    },
    "browsermcp": {
      "command": "npx",
      "args": ["-y", "@browsermcp/mcp@latest"]
    },
    "ide-browser-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["node_modules/tsx/dist/cli.mjs", "src/index.ts"],
      "cwd": "ide-browser-mcp",
      "description": "Chrome-mcp style: getPageInfo, clickElementByIndex, focusElementByIndex, type, navigate. Uses Playwright."
    }
  }
}
