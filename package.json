{
  "name": "vin-decoder",
  "private": true,
  "scripts": {
    "build": "react-router build",
    "dev": "shopify app dev",
    "theme:dev": "shopify theme dev --path theme --store speedy-motor-group-dev.myshopify.com",
    "theme:push": "shopify theme push --path theme --store speedy-motor-group-dev.myshopify.com",
    "theme:push-live": "shopify theme push --path theme --store speedy-motor-group-dev.myshopify.com --theme 153925681304 --allow-live",
    "theme:push-live-store": "shopify theme push --path theme --store speedy-motor-group.myshopify.com --theme 184117854488 --allow-live --force",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "react-router-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm run start",
    "setup": "prisma generate && prisma migrate deploy",
    "db:fix-session": "node scripts/drop-duplicate-session-table.js",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit",
    "unused:check": "knip --config knip.json --include files,dependencies,unlisted,exports",
    "test": "vitest run",
    "test:watch": "vitest run --watch",
    "check:option-a": "node scripts/check-option-a.js"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "zod": "^3.24.0",
    "@prisma/client": "^6.16.3",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^8.0.0",
    "@vercel/react-router": "^1.2.5",
    "isbot": "^5.1.31",
    "lru-cache": "^10.2.0",
    "prisma": "^6.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@graphql-codegen/introspection": "^5.0.0",
    "@graphql-codegen/typescript": "^5.0.8",
    "@react-router/dev": "^7.13.0",
    "@react-router/fs-routes": "^7.13.0",
    "@react-router/node": "^7.13.0",
    "@react-router/serve": "^7.13.0",
    "@shopify/api-codegen-preset": "^1.2.2",
    "@shopify/polaris-types": "^1.0.1",
    "@shopify/shopify-api": "^12.3.0",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "graphql-config": "^5.1.5",
    "knip": "^5.84.1",
    "react-router": "^7.13.0",
    "sharp": "^0.33.5",
    "typescript": "^5.9.3",
    "vite": "^6.3.6",
    "vitest": "^2.1.0"
  },
  "workspaces": [
    "extensions/*"
  ],
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "overrides": {
    "p-map": "^4.0.0",
    "minimatch": "^10.2.1",
    "ajv": "^8.18.0"
  },
  "author": "Air_M"
}
